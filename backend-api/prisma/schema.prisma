generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Feature {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  userId      Int
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([name])
  @@index([userId, createdAt])
}

model Plan {
  id   Int    @id @default(autoincrement())
  name String @unique

  maxFeatures        Int @default(3)
  rateLimitPerMinute Int @default(10)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]
}

enum Role {
  ADMIN
  PRO
  FREE
}

model User {
  id                  Int       @id @default(autoincrement())
  email               String    @unique
  password            String
  role                Role      @default(FREE)
  refreshToken        String?
  refreshTokenJti     String?
  planId              Int
  failedLoginAttempts Int       @default(0)
  lockUntil           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  features Feature[]

  plan          Plan           @relation(fields: [planId], references: [id])
  refreshTokens RefreshToken[]
}

model RefreshToken {
  id            String    @id @default(uuid())
  userId        Int
  hashedToken   String
  jti           String    @unique
  familyId      String
  parentJti     String?
  replacedByJti String?
  revokedAt     DateTime?
  expiresAt     DateTime
  revoked       Boolean
  ipAddress     String?
  userAgent     String?
  deviceHash    String?
  createdAt     DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])
}
